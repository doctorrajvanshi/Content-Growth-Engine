# Bot Tokens — REQUIRED for all platform bots
# Get from @BotFather on Telegram: /mybots → select bot → API Token
#
# All tokens are loaded via python-dotenv from this file.
# NEVER commit .env to git — it's in .gitignore.

# Approval bot (gateway + approve/reject flow)
APPROVAL_BOT_TOKEN=
APPROVAL_CHAT_ID=

# Platform bots (forward_to_telegram.py + platform_bot_listener.py)
REDDIT_BOT_TOKEN=
QA_BOT_TOKEN=
LINKEDIN_BOT_TOKEN=
LINKEDIN_CHAT_ID=
TWITTER_BOT_TOKEN=

# Playwright (optional, for URL fetching with cookies)
PLAYWRIGHT_COOKIE_DIR=.pw_cookies
